# At least one output channel is required for a normal run (not --dry-run):
# Google Sheets (ID + service account), SMTP email, or Telegram below.

# --- Google Sheets (optional if you use email or Telegram only) ---
GOOGLE_SHEETS_ID=
# Paste full JSON on one line, or use file path below (one of the two)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# Log tab name (Pattern A). Ignored for Pattern B except as fallback name.
GOOGLE_SHEET_TAB=log

# log = single worksheet, idempotent overwrite by run_date column
# daily = one worksheet per day (title YYYY-MM-DD), full replace each run
SHEET_LAYOUT=log

# Optional: parsed in config for future dynamic screeners (JSON array/object)
TRADINGVIEW_SCREENERS=

# --- SMTP email (optional if you use Sheets or Telegram) ---
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# --- Telegram (optional if you use Sheets or email) ---
# Create a bot with @BotFather; chat ID = your user ID (DM) or group ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional
LOG_LEVEL=INFO
# Set to 1 to skip all outputs without CLI flag (useful on Railway for testing)
DRY_RUN=0
