# Google Sheets (required unless --dry-run)
GOOGLE_SHEETS_ID=
# Paste full JSON on one line, or use file path below (one of the two)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# Log tab name (Pattern A). Ignored for Pattern B except as fallback name.
GOOGLE_SHEET_TAB=log

# log = single worksheet, idempotent overwrite by run_date column
# daily = one worksheet per day (title YYYY-MM-DD), full replace each run
SHEET_LAYOUT=log

# Optional: parsed in config for future dynamic screeners (JSON array/object)
TRADINGVIEW_SCREENERS=

# SMTP email (required unless --dry-run)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# Optional
LOG_LEVEL=INFO
# Set to 1 to skip Sheets + email without CLI flag (useful on Railway for testing)
DRY_RUN=0
